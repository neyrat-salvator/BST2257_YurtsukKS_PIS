{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Python Debugger: Current File",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "console": "internalConsole"
        },
        {
            "name": "PowerShell Launch Current File",
            "type": "PowerShell",
            "request": "launch",
            "script": "${file}",
            "cwd": "${cwd}"
        },
        {
            "name": "Python Debugger: Python file with arguments",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            // "program": "main.py",
            "console": "internalConsole",
            "args": ["runserver"]
        }
    ]
}